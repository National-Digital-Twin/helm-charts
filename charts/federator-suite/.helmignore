# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/

# Exclude development files
values-secrets.yaml
values/overrides/*/secrets.yaml
values/overrides/*/secrets/*.yaml
values/dry-run.yaml
kind-config.yaml
Makefile
scripts/
environments/
documentation/
*.md
VALUES-*.md
NAMING-*.md
